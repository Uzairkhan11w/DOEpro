Package: DOEpro
Title: Analysis of Designed Agricultural Experiments
Version: 2.0.0
Authors@R: c(
    person("Immad A.", "Shah", email = "immad11w@skuastkashmir.ac.in",
           role = "aut", comment = c(ORCID = "0000-0003-2761-5112")),
